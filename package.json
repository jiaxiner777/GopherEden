{
  "name": "code-mate",
  "displayName": "vscode宠物：工位搭子",
  "description": "在 VS Code 里陪你写代码的像素宠物搭子插件。",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiaxiner777/GopherEden.git"
  },
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:gophersEden.sidebar",
    "onView:gophersEden.dock",
    "onCommand:gophersEden.openHabitat",
    "onCommand:gophersEden.openDock",
    "onCommand:gophersEden.renamePet",
    "onCommand:gophersEden.playWithPet",
    "onCommand:gophersEden.redetectLineage",
    "onCommand:gophersEden.switchTheme",
    "onCommand:gophersEden.toggleEditorPet"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gophersEden",
          "title": "vscode宠物：工位搭子",
          "icon": "media/ui/activity-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "gophersEdenPanel",
          "title": "底部乐园",
          "icon": "media/ui/activity-icon.svg"
        }
      ]
    },
    "views": {
      "gophersEden": [
        {
          "id": "gophersEden.sidebar",
          "name": "vscode宠物：工位搭子",
          "type": "webview",
          "icon": "media/ui/activity-icon.svg"
        }
      ],
      "gophersEdenPanel": [
        {
          "id": "gophersEden.dock",
          "name": "底部乐园",
          "type": "webview",
          "icon": "media/ui/activity-icon.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "gophersEden.openHabitat",
        "title": "vscode宠物：工位搭子：打开 vscode宠物：工位搭子"
      },
      {
        "command": "gophersEden.openDock",
        "title": "vscode宠物：工位搭子：打开底部乐园"
      },
      {
        "command": "gophersEden.renamePet",
        "title": "vscode宠物：工位搭子：给宠物起名"
      },
      {
        "command": "gophersEden.playWithPet",
        "title": "vscode宠物：工位搭子：逗一逗宠物"
      },
      {
        "command": "gophersEden.redetectLineage",
        "title": "vscode宠物：工位搭子：重新判断宠物种族"
      },
      {
        "command": "gophersEden.toggleEditorPet",
        "title": "vscode宠物：工位搭子：切换代码区宠物显示"
      },
      {
        "command": "gophersEden.switchTheme",
        "title": "vscode宠物：工位搭子：切换主题"
      }
    ],
    "keybindings": [
      {
        "command": "gophersEden.playWithPet",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "vscode宠物：工位搭子",
      "properties": {
        "gophersEden.renderDebounceMs": {
          "type": "number",
          "default": 120,
          "minimum": 50,
          "description": "编辑器宠物与家具 decoration 的防抖渲染间隔。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && node ./node_modules/@vscode/vsce/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^2.25.0",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.2"
  },
  "files": [
    "dist/**",
    "media/**",
    "README.md",
    "LICENSE",
    "package.json"
  ]
}
