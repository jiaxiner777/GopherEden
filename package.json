{
  "name": "gophers-eden",
  "displayName": "Gopher 乐园",
  "description": "在 VS Code 里陪你写代码的电子宠物与像素伊甸园。",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiaxiner777/GopherEden.git"
  },
  "publisher": "local",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:gophersEden.sidebar",
    "onView:gophersEden.dock",
    "onCommand:gophersEden.openHabitat",
    "onCommand:gophersEden.openDock",
    "onCommand:gophersEden.renamePet",
    "onCommand:gophersEden.playWithPet",
    "onCommand:gophersEden.switchTheme",
    "onCommand:gophersEden.toggleEditorPet"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gophersEden",
          "title": "Gopher 乐园",
          "icon": "media/activity-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "gophersEdenPanel",
          "title": "Gopher 底部乐园",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "gophersEden": [
        {
          "id": "gophersEden.sidebar",
          "name": "伊甸面板",
          "type": "webview",
          "icon": "media/activity-icon.svg"
        }
      ],
      "gophersEdenPanel": [
        {
          "id": "gophersEden.dock",
          "name": "底部乐园",
          "type": "webview",
          "icon": "media/activity-icon.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "gophersEden.openHabitat",
        "title": "Gopher 乐园：打开伊甸面板"
      },
      {
        "command": "gophersEden.openDock",
        "title": "Gopher 乐园：打开底部乐园"
      },
      {
        "command": "gophersEden.renamePet",
        "title": "Gopher 乐园：给宠物起名"
      },
      {
        "command": "gophersEden.playWithPet",
        "title": "Gopher 乐园：逗一逗宠物"
      },
      {
        "command": "gophersEden.toggleEditorPet",
        "title": "Gopher 乐园：切换代码区宠物显示"
      },
      {
        "command": "gophersEden.switchTheme",
        "title": "Gopher 乐园：切换主题"
      }
    ],
    "keybindings": [
      {
        "command": "gophersEden.playWithPet",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Gopher 乐园",
      "properties": {
        "gophersEden.renderDebounceMs": {
          "type": "number",
          "default": 120,
          "minimum": 50,
          "description": "编辑器宠物与家具 decoration 的防抖渲染间隔。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && node ./node_modules/@vscode/vsce/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.8.0",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.2"
  },
  "files": [
    "dist/**",
    "media/**",
    "README.md",
    "package.json"
  ]
}
